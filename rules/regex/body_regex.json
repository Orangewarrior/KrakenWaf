{
  "rules": [
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Command injection separators body",
      "severity": "critical",
      "cwe": "CWE-78",
      "description": "Detects shell metacharacters combined with common execution primitives in request bodies.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:;\\s*(?:wget|curl|bash|sh|python|perl|php|powershell|cmd)|\\|\\|?\\s*(?:wget|curl|bash|sh|python|perl|php|powershell|cmd)|&&\\s*(?:wget|curl|bash|sh|python|perl|php|powershell|cmd))",
      "id": "00001"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Command substitution body",
      "severity": "critical",
      "cwe": "CWE-78",
      "description": "Detects command substitution in body payloads.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:\\$\\((?:id|whoami|uname|curl|wget|bash|sh)|`(?:id|whoami|uname|curl|wget|bash|sh))",
      "id": "00002"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Shell downloader body",
      "severity": "high",
      "cwe": "CWE-78",
      "description": "Detects common downloader command chains in body content.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:wget\\s+https?://|curl\\s+-[fsSLoO].*https?://|powershell(?:\\.exe)?\\s+-enc|certutil(?:\\.exe)?\\s+-urlcache\\s+-split\\s+-f)",
      "id": "00003"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Reverse shell body",
      "severity": "critical",
      "cwe": "CWE-78",
      "description": "Detects reverse shell primitives in body content.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:nc\\s+-e|bash\\s+-i\\s*>&|/dev/tcp/\\d{1,3}(?:\\.\\d{1,3}){3}/\\d+|python(?:3)?\\s+-c\\s+[\"\\'].*socket)",
      "id": "00004"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "LFI file disclosure body",
      "severity": "high",
      "cwe": "CWE-22",
      "description": "Detects direct references to sensitive files in body content.",
      "url": "https://cwe.mitre.org/data/definitions/22.html",
      "rule_match": "(?i)(?:/etc/passwd|/etc/shadow|/proc/self/environ|boot\\.ini|win\\.ini|\\\\windows\\\\system32)",
      "id": "00005"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Traversal body encoded",
      "severity": "high",
      "cwe": "CWE-22",
      "description": "Detects traversal sequences in body payloads.",
      "url": "https://cwe.mitre.org/data/definitions/22.html",
      "rule_match": "(?i)(?:\\.\\./|\\.\\.\\\\|%2e%2e(?:%2f|/|%5c|\\\\)|%252e%252e%252f)",
      "id": "00006"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "PHP wrapper body",
      "severity": "high",
      "cwe": "CWE-98",
      "description": "Detects dangerous PHP wrapper usage in body payloads.",
      "url": "https://cwe.mitre.org/data/definitions/98.html",
      "rule_match": "(?i)(?:php://(?:filter|input|fd)|phar://|zip://|data://text/html)",
      "id": "00007"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "RFI body remote include",
      "severity": "high",
      "cwe": "CWE-98",
      "description": "Detects remote include style body parameters.",
      "url": "https://cwe.mitre.org/data/definitions/98.html",
      "rule_match": "(?i)(?:=https?://[^\\s&]+\\.(?:php|txt|inc|jsp)|=ftp://)",
      "id": "00008"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "SSRF localhost body",
      "severity": "critical",
      "cwe": "CWE-918",
      "description": "Detects localhost SSRF targets in body content.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:https?://(?:127\\.0\\.0\\.1|localhost|0\\.0\\.0\\.0|\\[::1\\]|169\\.254\\.169\\.254))",
      "id": "00009"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "SSRF private body",
      "severity": "critical",
      "cwe": "CWE-918",
      "description": "Detects internal/private IPv4 SSRF targets in body.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:https?://(?:10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(?:1[6-9]|2\\d|3[0-1])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3}))",
      "id": "00010"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "SSRF cloud metadata body",
      "severity": "critical",
      "cwe": "CWE-918",
      "description": "Detects cloud metadata endpoints in body content.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:metadata\\.google\\.internal|100\\.100\\.100\\.200|latest/meta-data|169\\.254\\.170\\.2)",
      "id": "00011"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "File and gopher schemes body",
      "severity": "high",
      "cwe": "CWE-918",
      "description": "Detects dangerous URL schemes in body content.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:file://|gopher://|dict://|smb://)",
      "id": "00012"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "SMTP or internal protocol abuse body",
      "severity": "medium",
      "cwe": "CWE-918",
      "description": "Detects unusual callback protocols in body payloads.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:ldap://|ldaps://|rmi://|dns://|smtp://|imap://|pop3://|tftp://)",
      "id": "00013"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Deserialization gadget body",
      "severity": "high",
      "cwe": "CWE-502",
      "description": "Detects serialized object markers and gadget hints.",
      "url": "https://cwe.mitre.org/data/definitions/502.html",
      "rule_match": "(?i)(?:O:\\d+:\"[A-Za-z_\\\\]+\"|rO0AB|__reduce__|java\\.lang\\.Runtime|TemplatesImpl|ysoserial)",
      "id": "00014"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Template injection body",
      "severity": "high",
      "cwe": "CWE-94",
      "description": "Detects obvious SSTI expressions in body payloads.",
      "url": "https://cwe.mitre.org/data/definitions/94.html",
      "rule_match": "(?i)(?:\\{\\{\\s*7\\s*\\*\\s*7\\s*\\}\\}|\\$\\{(?:7\\*7|jndi:)|<%=|\\{\\%.*\\%\\}|\\#set\\()",
      "id": "00015"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Protocol smuggling body",
      "severity": "medium",
      "cwe": "CWE-444",
      "description": "Detects CRLF/header smuggling primitives in body content.",
      "url": "https://cwe.mitre.org/data/definitions/444.html",
      "rule_match": "(?i)(?:%0d%0a|\\r\\n)(?:host:|content-length:|transfer-encoding:|x-forwarded-)",
      "id": "00016"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "SSRF redirect parameter body",
      "severity": "medium",
      "cwe": "CWE-601",
      "description": "Detects open redirect/SSRF parameter values in bodies.",
      "url": "https://cwe.mitre.org/data/definitions/601.html",
      "rule_match": "(?i)(?:\\b(?:url|uri|next|redirect|dest|continue|return|endpoint)=\\s*(?:https?://|//|file://|gopher://))",
      "id": "00017"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Archive traversal body",
      "severity": "medium",
      "cwe": "CWE-22",
      "description": "Detects Zip Slip style relative extraction paths in bodies.",
      "url": "https://cwe.mitre.org/data/definitions/22.html",
      "rule_match": "(?i)(?:\\.\\./.*\\.(?:jsp|php|aspx|war|jar)|\\.{2}(?:/|\\\\).*(?:web\\.xml|application\\.properties))",
      "id": "00018"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Known scanner body",
      "severity": "medium",
      "cwe": "CWE-16",
      "description": "Detects common scanner strings in body content.",
      "url": "https://owasp.org/www-community/attacks/Web_Application_Firewall",
      "rule_match": "(?i)(?:sqlmap|acunetix|nikto|nessus|nuclei|masscan|zgrab)",
      "id": "00019"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Suspicious XML external entity body",
      "severity": "high",
      "cwe": "CWE-611",
      "description": "Detects classic XXE primitives in body content.",
      "url": "https://cwe.mitre.org/data/definitions/611.html",
      "rule_match": "(?i)(?:<!DOCTYPE\\s+[^>]+\\s+\\[|<!ENTITY\\s+[^>]+SYSTEM\\s+[\"\\'](?:file|http|https|ftp)://)",
      "id": "00020"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Suspicious log4shell body",
      "severity": "critical",
      "cwe": "CWE-94",
      "description": "Detects JNDI lookup expressions in body content.",
      "url": "https://cwe.mitre.org/data/definitions/94.html",
      "rule_match": "(?i)(?:\\$\\{jndi:(?:ldap|ldaps|rmi|dns|iiop|nis|nds|http)://)",
      "id": "00021"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Windows shell body",
      "severity": "critical",
      "cwe": "CWE-78",
      "description": "Detects cmd.exe or powershell execution markers.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:cmd(?:\\.exe)?\\s+/c|powershell(?:\\.exe)?\\s+-enc|powershell(?:\\.exe)?\\s+-nop)",
      "id": "00022"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Unix shell body",
      "severity": "critical",
      "cwe": "CWE-78",
      "description": "Detects direct Unix shell invocation markers.",
      "url": "https://cwe.mitre.org/data/definitions/78.html",
      "rule_match": "(?i)(?:/bin/(?:sh|bash)\\s+-c|sh\\s+-c|bash\\s+-c)",
      "id": "00023"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Container escape body",
      "severity": "medium",
      "cwe": "CWE-250",
      "description": "Detects access to container or orchestrator secrets.",
      "url": "https://cwe.mitre.org/data/definitions/250.html",
      "rule_match": "(?i)(?:docker\\.sock|/var/run/secrets/kubernetes\\.io/serviceaccount|/run/secrets/)",
      "id": "00024"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Unsafe file upload body",
      "severity": "medium",
      "cwe": "CWE-434",
      "description": "Detects executable upload extensions in multipart names.",
      "url": "https://cwe.mitre.org/data/definitions/434.html",
      "rule_match": "(?i)(?:filename\\s*=\\s*\"[^\"]+\\.(?:php\\d*|phtml|phar|jsp|jspx|asp|aspx|cfm|cgi|pl|sh|war|jar)\")",
      "id": "00025"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Path traversal zip slip body",
      "severity": "medium",
      "cwe": "CWE-22",
      "description": "Detects archive member traversal paths.",
      "url": "https://cwe.mitre.org/data/definitions/22.html",
      "rule_match": "(?i)(?:filename\\s*=\\s*\"(?:\\.\\./|\\.\\.\\\\))",
      "id": "00026"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Dangerous binary fetch body",
      "severity": "high",
      "cwe": "CWE-494",
      "description": "Detects package manager driven remote installs.",
      "url": "https://cwe.mitre.org/data/definitions/494.html",
      "rule_match": "(?i)(?:apt(?:-get)?\\s+install\\s+|yum\\s+install\\s+|dnf\\s+install\\s+|pip(?:3)?\\s+install\\s+https?://)",
      "id": "00027"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "OCI metadata SSRF body",
      "severity": "critical",
      "cwe": "CWE-918",
      "description": "Detects OCI metadata endpoints in body content.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:opc/v2/instance/|openstack/latest/meta_data\\.json|computeMetadata/v1/)",
      "id": "00028"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "GraphQL introspection body",
      "severity": "medium",
      "cwe": "CWE-200",
      "description": "Detects GraphQL introspection probes in body content.",
      "url": "https://cwe.mitre.org/data/definitions/200.html",
      "rule_match": "(?i)(?:__schema|__type|IntrospectionQuery)",
      "id": "00029"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Server-side include body",
      "severity": "medium",
      "cwe": "CWE-97",
      "description": "Detects SSI directives in body content.",
      "url": "https://cwe.mitre.org/data/definitions/97.html",
      "rule_match": "(?i)(?:<!--#(?:exec|include|echo|printenv)\\s+)",
      "id": "00030"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Localhost callback body",
      "severity": "high",
      "cwe": "CWE-918",
      "description": "Detects localhost callback parameters in body.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:\\b(?:callback|webhook|feed|proxy|fetch|target|host)=\\s*(?:https?://)?(?:127\\.0\\.0\\.1|localhost|0\\.0\\.0\\.0))",
      "id": "00031"
    },
    {
      "enable": 0,
      "http_action": "Request",
      "title": "SSRF unix socket body",
      "severity": "high",
      "cwe": "CWE-918",
      "description": "Detects unix socket SSRF notations in body content.",
      "url": "https://cwe.mitre.org/data/definitions/918.html",
      "rule_match": "(?i)(?:unix:(?://)?/|http\\+unix://|curl\\s+--unix-socket)",
      "id": "00032"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "Header smuggling body",
      "severity": "medium",
      "cwe": "CWE-444",
      "description": "Detects HTTP/2 or transfer encoding smuggling hints in body.",
      "url": "https://cwe.mitre.org/data/definitions/444.html",
      "rule_match": "(?i)(?:transfer-encoding\\s*:\\s*chunked|content-length\\s*:\\s*\\d+.*transfer-encoding)",
      "id": "00033"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "XSS DOM event handler body",
      "severity": "high",
      "cwe": "CWE-79",
      "description": "Detects common DOM event handler attribute injection in POST bodies.",
      "url": "https://cwe.mitre.org/data/definitions/79.html",
      "rule_match": "(?i)\\bon(?:click|focus|blur|submit|mouseover|mouseenter|mousemove|toggle|start|end|animationend|transitionend|keyup|keydown|keypress|input|change|reset|select|copy|cut|paste|drag|drop|scroll|wheel|pointerdown|pointerup)\\s*=",
      "id": "00034"
    },
    {
      "enable": 1,
      "http_action": "Request",
      "title": "SQLi time-based and error-based probes body",
      "severity": "critical",
      "cwe": "CWE-89",
      "description": "Detects time-based blind, error-based, and structural SQLi probes in POST bodies.",
      "url": "https://cwe.mitre.org/data/definitions/89.html",
      "rule_match": "(?i)(?:sleep\\s*\\(\\s*[0-9]+|waitfor\\s+delay\\b|benchmark\\s*\\(\\s*[0-9]+|extractvalue\\s*\\(|updatexml\\s*\\(|union\\s+(?:all\\s+)?select\\b|'\\s*(?:or|and)\\s+(?:'[^']*'|[0-9])\\s*[=<>]|'\\s*\\)\\s*or\\s*\\(\\s*'|'\\s*(?:--|#)(?:\\s|$)|'\\s*/\\*|or\\s+true\\b|[0-9]+\\s+(?:or|and)\\s+[0-9]+=\\s*[0-9]+|\"\\s*or\\s+(?:\"[^\"]*\"\\s*=|[0-9])|(?:or|and)\\s+\\(\\s*select\\b|;\\s*(?:select|insert|update|delete|drop|exec)\\b|'\\s*having\\s+[0-9]|'\\s*order\\s+by\\s+[0-9]|'\\s*group\\s+by\\s+[0-9]|xp_cmdshell|drop\\s+table\\s+\\w|insert\\s+into\\s+\\w+\\s+values|exec\\s+(?:master|xp_))",
      "id": "00035"
    }
  ]
}